# Copy this file to .env and fill in real values. .env is gitignored.

# --- VaultRE API (read scope: advertising.read, contact.read, property.read) ---
VAULTRE_API_BASE=https://ap-southeast-2.api.vaultre.com.au/api/v1.3
VAULTRE_API_KEY=
VAULTRE_API_TOKEN=

# --- Mobile uploader ---
# Base URL the chat will tell users to open on their phone or laptop.
# Localhost is fine when developing on the same Mac. For multi-device use,
# point this at the Mac's Tailscale MagicDNS name plus the uploader port,
# e.g. http://harcourts-mac.tail-xxx.ts.net:8080
HARCOURTS_UPLOADER_BASE_URL=http://localhost:8080

# Copy this file to .env and fill in real values. .env is gitignored.
#
# Running `./scripts/install.sh` (no subcommand) will prompt for any
# missing required values and write them in for you. You can also fill
# this in by hand and skip the prompts.

# --- VaultRE API (read scope: advertising.read, contact.read, property.read) ---
# Used by scripts/vaultre.sh (the CLI Claude calls during the chat workflow
# to pull property metadata, photos, and floor plans). See
# integrations/vaultre/ANALYSIS.md for the deeper API rationale.
VAULTRE_API_BASE=https://ap-southeast-2.api.vaultre.com.au/api/v1.3
VAULTRE_API_KEY=
VAULTRE_API_TOKEN=

# --- Backend auth (production gate) ---
# HARCOURTS_REQUIRE_AUTH=true makes the backend reject any /api/* or
# /ws/chat request without a valid Supabase JWT. Required on Neo or
# any host whose Funnel URL is going to be reachable from the public
# internet. Set to false ONLY for local dev where you don't have a
# Supabase session in your hand.
HARCOURTS_REQUIRE_AUTH=true

# HS256 secret that Supabase uses to sign HUP-Sales-App's session
# JWTs. Find it in Supabase admin → Project Settings → API → JWT
# Secret. The Neo backend verifies every incoming token against this.
# DO NOT commit this file with the real secret filled in.
HARCOURTS_SUPABASE_JWT_SECRET=

# Optional: override the JWT audience claim. Supabase defaults to
# "authenticated"; only change this if your tenant uses a custom one.
# HARCOURTS_SUPABASE_JWT_AUD=authenticated

# Optional: in dev mode (HARCOURTS_REQUIRE_AUTH=false), the synthesised
# stub user's email is this. Just an audit/display value.
# HARCOURTS_DEV_USER_NAME=dev@local

# Optional: override the backend port. The default 8787 was chosen to
# avoid Obsidian / Node dev-server collisions on 3000.
# HARCOURTS_BACKEND_PORT=8787
